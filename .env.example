# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# YouTube Configuration
YOUTUBE_CLIENT_ID=your_client_id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your_client_secret
YOUTUBE_REFRESH_TOKEN=your_refresh_token

# Video Configuration
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720
VIDEO_FPS=30
VIDEO_DURATION=120  # segundos

# Audio Configuration
VOICE_LANGUAGE=es
VOICE_SLOW=False

# Output Configuration
OUTPUT_DIR=./output
VIDEOS_DIR=./output/videos
TEMP_DIR=./output/temp

# Scheduler Configuration
SCHEDULER_ENABLED=True
SCHEDULER_TIMEZONE=America/Mexico_City

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/agent.log

# Animation Colors (RGB)
PRIMARY_COLOR=255,100,150
SECONDARY_COLOR=100,200,255
BACKGROUND_COLOR=255,255,240

# Story Configuration
STORY_TONE=friendly,educational,fun
STORY_MIN_LENGTH=5
STORY_MAX_LENGTH=15
